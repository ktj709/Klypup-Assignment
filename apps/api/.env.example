APP_NAME=Klypup Research API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/klypup
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=your-api-audience
AUTH0_ALGORITHMS=RS256
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash
NEWS_API_KEY=your-newsapi-key
FAISS_INDEX_PATH=data/faiss/index.bin
FAISS_META_PATH=data/faiss/meta.json
CORS_ORIGINS=http://localhost:3000
EXTERNAL_REQUEST_TIMEOUT_SECONDS=12
EXTERNAL_REQUEST_RETRIES=2
REQUEST_LOGGING_ENABLED=true
